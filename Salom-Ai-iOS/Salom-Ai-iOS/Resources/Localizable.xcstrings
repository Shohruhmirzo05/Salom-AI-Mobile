    "Yorug‘" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Light"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Светлая"
          }
        },
        "uz-Cyrl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ёруғ"
          }
        }
      }
    },
    "Yozing, savol bering, fikrlashing. AI sizning matnlaringizga aniq va tabiiy javob beradi — o'zbek, rus va ingliz tillarida." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Write, ask and explore ideas. AI responds clearly and naturally in Uzbek, Russian and English."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Пишите, задавайте вопросы и развивайте идеи. AI отвечает ясно и естественно на узбекском, русском и английском."
          }
        },
        "uz-Cyrl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ёзинг, савол беринг, фикрлашинг. АИ сизнинг матнларингизга аниқ ва табиий жавоб беради — ўзбек, рус ва инглиз тилларида."
          }
        }
      }
    },
    "Yozish shart emas. Shunchaki gapiring va tabiiy ovozda javob oling. Haqiqiy suhbatdosh kabi." : {
      "comment" : "Onboarding slide subtitle about speaking instead of typing.",
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No need to type. Just talk and get a natural-sounding reply. Like chatting with a real friend."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Не нужно печатать. Просто говорите и получайте естественный ответ. Как с настоящим собеседником."
          }
        },
        "uz-Cyrl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ёзиш шарт эмас. Шунчаки гапиринг ва табиий овозда жавоб олинг. Ҳақиқий суҳбатдош каби."
          }
        }
      }
    },
