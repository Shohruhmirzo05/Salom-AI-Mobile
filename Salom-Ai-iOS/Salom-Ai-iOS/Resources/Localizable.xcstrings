        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы уверены, что хотите полностью удалить свой аккаунт? Это действие удалит все ваши чаты, сообщения и данные без возможности восстановления!"
          }
        },
        "uz-Cyrl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ҳисобингизни бутунлай ўчиришни хоҳлайсизми? Бу амал барча суҳбатлар, хабарлар ва ма'лумотларингизни бутунлай ўчиради. Бу амални бекор қилиб бўлмайди!"
          }
        }
