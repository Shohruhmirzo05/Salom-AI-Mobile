        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solve everyday tasks on the go—from math and coding to daily plans and travel routes."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Решайте повседневные задачи на ходу: математика, программирование, планы и маршруты."
          }
        },
        "uz-Cyrl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Математика, дастурлаш, кунлик режа, саёҳат маршрути — енг керакли вазифаларни йўлда ҳал қилинг."
